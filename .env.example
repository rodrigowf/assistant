# Personal Assistant Configuration
# Copy this file to .env and customize as needed.
# Environment variables override .manager.json settings.

# Session provider — which agent backs chat sessions.
# Options: claude (Claude Code), qwen (Qwen Code)
# The UI can also flip this at runtime; the env var wins only if no UI value is set.
# ASSISTANT_PROVIDER=claude

# Default model for the configured provider.
# Claude examples: claude-sonnet-4-5-20250929, claude-opus-4-7
# Qwen examples:   qwen3.6-plus, qwen3-coder-plus
# MANAGER_MODEL=claude-sonnet-4-5-20250929

# Permission mode (Claude only; ignored when provider=qwen).
# Options: default, plan, auto-accept
# MANAGER_PERMISSION_MODE=default

# Maximum spend per session (in USD; Claude only).
# MANAGER_MAX_BUDGET_USD=10.0

# Maximum turns per session.
# MANAGER_MAX_TURNS=50

# Project directory (defaults to current directory).
# MANAGER_PROJECT_DIR=/path/to/project

# Path to the qwen CLI (only needed if not on $PATH; ignored when provider=claude).
# QWEN_CLI_PATH=/home/you/.nvm/versions/node/v22.21.1/bin/qwen
