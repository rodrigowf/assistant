# context-sync configuration
# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit it (contains paths/keys).

# Local directory to sync (absolute path, no trailing slash)
LOCAL_DIR=/home/youruser/Projects/assistant/context

# Remote machine
REMOTE_HOST=192.168.0.200
REMOTE_USER=youruser

# Remote directory to sync to (absolute path, no trailing slash)
REMOTE_DIR=/home/youruser/assistant/context

# SSH private key for passwordless auth (must be set up in advance)
SSH_KEY=/home/youruser/.ssh/id_ed25519

# Seconds to wait after last file change before triggering rsync (debounce)
# Increase if you see excessive sync events during long streaming responses
DEBOUNCE_SECONDS=2

# Seconds to wait before retrying when remote is offline
RETRY_INTERVAL=30
