<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — AssistantDevice configuration screen.

    Structure:
      ScrollView
        LinearLayout (vertical root)
          ── Header card: app title + ADB address + last boot time
          ── Warning banner: shown only if WRITE_SECURE_SETTINGS is missing
          ── Feature section: one card per feature with a Switch and status line
          ── Action buttons: "Apply All Now" and "Set as Home App"

    Styling: dark background (#1a1a1a), teal primary (#00bcd4), white text.
    No AppCompat — uses android.widget.* directly (API 21 native Material theme).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── App title ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:paddingBottom="16dp" />

        <!-- ── Status card ───────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- ADB address: updated in onResume with live IP -->
            <TextView
                android:id="@+id/tv_adb_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ADB: —"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:paddingBottom="4dp" />

            <!-- Last boot time recorded by BootReceiver -->
            <TextView
                android:id="@+id/tv_last_boot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last boot: —"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- ── Setup warning banner ──────────────────────────────────────── -->
        <!--
            Shown when WRITE_SECURE_SETTINGS has not been granted.
            Hidden (GONE) once the permission is present.
            Grant command: adb shell pm grant com.assistant.device android.permission.WRITE_SECURE_SETTINGS
        -->
        <LinearLayout
            android:id="@+id/tv_setup_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#3df44336"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/warning_title"
                android:textColor="@color/status_error"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/warning_body"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- ── Section label ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_features"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:paddingBottom="8dp" />

        <!-- ── WiFi ADB feature row ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_wifi_adb"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_wifi_adb_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- android.widget.Switch — available since API 14, no AppCompat needed -->
                <Switch
                    android:id="@+id/switch_wifi_adb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Live status line: shows "192.168.x.x:5555" or "Disabled" -->
            <TextView
                android:id="@+id/tv_wifi_adb_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/status_active"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingTop="6dp" />

        </LinearLayout>

        <!-- ── Auto-launch feature row ───────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_auto_launch"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_auto_launch_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_auto_launch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_auto_launch_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/status_active"
                android:textSize="12sp"
                android:paddingTop="6dp" />

        </LinearLayout>

        <!-- ── CPU Governor feature row ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_cpu_governor"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_cpu_governor_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_cpu_governor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Shows current governor, e.g. "Current: interactive (×4)" -->
            <TextView
                android:id="@+id/tv_cpu_governor_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/status_inactive"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingTop="6dp" />

        </LinearLayout>

        <!-- ── Do Not Disturb feature row ────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_dnd"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_dnd_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_dnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_dnd_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/status_active"
                android:textSize="12sp"
                android:paddingTop="6dp" />

        </LinearLayout>

        <!-- ── Watchdog feature row ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_watchdog"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_watchdog_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_watchdog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_watchdog_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/status_active"
                android:textSize="12sp"
                android:paddingTop="6dp" />

        </LinearLayout>

        <!-- ── Action buttons ────────────────────────────────────────────── -->

        <!--
            "Apply All Now": runs all enabled features immediately, without waiting
            for a reboot. Useful after first install or permission grant.
        -->
        <Button
            android:id="@+id/btn_apply_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_apply_all"
            android:layout_marginBottom="8dp" />

        <!--
            "Set as Home App": opens the system's "Choose home app" dialog.
            This is the only way without root/Device Owner to set a default launcher.
        -->
        <Button
            android:id="@+id/btn_set_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_set_home"
            android:textColor="@color/primary"
            android:background="@android:color/transparent"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
