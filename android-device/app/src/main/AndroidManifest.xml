<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        WRITE_SECURE_SETTINGS: Cannot be self-granted via manifest alone.
        Must be granted ONCE via USB after install:
            adb shell pm grant com.assistant.device android.permission.WRITE_SECURE_SETTINGS
        Survives app updates but NOT reinstalls. Required for WiFi ADB and DND features.
    -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />

    <!-- Required for BootReceiver to receive ACTION_BOOT_COMPLETED -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- For DND on API 23+. On API 21-22 zen_mode via Settings.Global is used instead. -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Read WiFi IP address for status display -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- WatchdogService runs as a foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Keep CPU awake during boot sequence and watchdog checks -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
        GET_TASKS: Deprecated in API 21 but improves getRunningAppProcesses() completeness
        on Android 5.0. Harmless on newer versions.
    -->
    <uses-permission android:name="android.permission.GET_TASKS" />

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:theme="@style/Theme.AssistantDevice">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            BootReceiver fires on every device boot.
            Priority 1000 ensures it runs before other receivers.
        -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!--
            WatchdogService: foreground service that monitors the assistant app
            and relaunches it if it dies. START_STICKY ensures Android restarts it.
        -->
        <service
            android:name=".service.WatchdogService"
            android:exported="false"
            android:enabled="true" />

    </application>
</manifest>
